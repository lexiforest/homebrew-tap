#!/usr/bin/env python3
"""Update Formula/curl-impersonate.rb from the latest GitHub release."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_FORMULA = REPO_ROOT / "Formula" / "curl-impersonate.rb"
GITHUB_REPO = "lexiforest/curl-impersonate"
LATEST_RELEASE_URL = f"https://api.github.com/repos/{GITHUB_REPO}/releases/latest"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Update the curl-impersonate Homebrew formula to the latest GitHub release.",
    )
    parser.add_argument(
        "--formula",
        type=Path,
        default=DEFAULT_FORMULA,
        help=f"formula to update, defaults to {DEFAULT_FORMULA.relative_to(REPO_ROOT)}",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print the updated formula without writing it",
    )
    return parser.parse_args()


def request(url: str) -> urllib.request.Request:
    headers = {
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2022-11-28",
        "User-Agent": "homebrew-tap-updater",
    }
    if token := os.environ.get("GITHUB_TOKEN"):
        headers["Authorization"] = f"Bearer {token}"
    return urllib.request.Request(url, headers=headers)


def fetch_json(url: str) -> dict[str, Any]:
    try:
        with urllib.request.urlopen(request(url)) as response:
            return json.load(response)
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8", errors="replace")
        raise SystemExit(f"GitHub API request failed: {error.code} {error.reason}\n{body}") from error
    except urllib.error.URLError as error:
        raise SystemExit(f"GitHub API request failed: {error.reason}") from error


def find_asset(assets: list[dict[str, Any]], tag: str, platform: str) -> dict[str, Any]:
    name = f"curl-impersonate-{tag}.{platform}.tar.gz"
    for asset in assets:
        if asset.get("name") == name:
            return asset
    raise SystemExit(f"Missing release asset: {name}")


def sha256_for(asset: dict[str, Any]) -> str:
    digest = asset.get("digest")
    if isinstance(digest, str) and re.fullmatch(r"sha256:[0-9a-f]{64}", digest):
        return digest.removeprefix("sha256:")

    url = asset["browser_download_url"]
    hasher = hashlib.sha256()
    with urllib.request.urlopen(request(url)) as response:
        while chunk := response.read(1024 * 1024):
            hasher.update(chunk)
    return hasher.hexdigest()


def replace_arch_block(formula: str, block_name: str, url: str, sha256: str) -> str:
    pattern = re.compile(
        rf'(?P<prefix>on_{block_name} do\n\s+url ")[^"]+'
        rf'(?P<middle>"\n\s+sha256 ")[0-9a-f]{{64}}'
        rf'(?P<suffix>"\n\s+end)'
    )
    updated, replacements = pattern.subn(
        rf"\g<prefix>{url}\g<middle>{sha256}\g<suffix>",
        formula,
        count=1,
    )
    if replacements != 1:
        raise SystemExit(f"Could not update on_{block_name} block")
    return updated


def update_formula(formula: str, release: dict[str, Any]) -> tuple[str, str]:
    tag = release["tag_name"]
    version = tag.removeprefix("v")
    assets = release["assets"]

    arm_asset = find_asset(assets, tag, "arm64-macos")
    intel_asset = find_asset(assets, tag, "x86_64-macos")

    formula, version_replacements = re.subn(
        r'^\s+version "[^"]+"',
        f'  version "{version}"',
        formula,
        count=1,
        flags=re.MULTILINE,
    )
    if version_replacements != 1:
        raise SystemExit("Could not update version")

    formula = replace_arch_block(
        formula,
        "arm",
        arm_asset["browser_download_url"],
        sha256_for(arm_asset),
    )
    formula = replace_arch_block(
        formula,
        "intel",
        intel_asset["browser_download_url"],
        sha256_for(intel_asset),
    )
    return formula, tag


def main() -> int:
    args = parse_args()
    formula_path = args.formula.resolve()
    release = fetch_json(LATEST_RELEASE_URL)
    updated_formula, tag = update_formula(formula_path.read_text(), release)

    if args.dry_run:
        print(updated_formula, end="")
    else:
        formula_path.write_text(updated_formula)
        print(f"Updated {formula_path.relative_to(REPO_ROOT)} to {tag}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
